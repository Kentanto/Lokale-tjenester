<?php
session_start();

/* ================================
   DATABASE CONNECTION
   ================================ */
$host = "localhost";
$db   = "DB";
$user = "pyx";
$pass = "admin";

$conn = new mysqli($host, $user, $pass, $db);
if ($conn->connect_error) die("DB connection failed: " . $conn->connect_error);

// Safe prepare helper: prepare a statement and log on failure instead of causing fatal errors
function safe_prepare($conn, $sql){
    $stmt = $conn->prepare($sql);
    if(!$stmt){
        error_log("DB prepare failed: " . $conn->error . " -- SQL: " . $sql);
        return null;
    }
    return $stmt;
}

// Ensure expected columns exist on `users` table to avoid SQL errors on older schemas.
$colsRes = $conn->query("SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA=DATABASE() AND TABLE_NAME='users'");
$existingCols = [];
if($colsRes && $colsRes instanceof mysqli_result){
    while($r = $colsRes->fetch_assoc()) $existingCols[] = $r['COLUMN_NAME'];
} else {
    // couldn't read schema info (permissions or missing DB) — log and continue without schema changes
    error_log('Could not read INFORMATION_SCHEMA for users table: ' . $conn->error);
    $existingCols = [];
}
// Add `email` column if missing
if(!in_array('email', $existingCols)){
    @$conn->query("ALTER TABLE users ADD COLUMN email VARCHAR(191) DEFAULT NULL");
}
// Add `password_hash` column if missing (some schemas used 'password' previously)
if(!in_array('password_hash', $existingCols)){
    if(in_array('password', $existingCols)){
        // rename existing 'password' to 'password_hash' to preserve data
        @$conn->query("ALTER TABLE users CHANGE COLUMN `password` `password_hash` VARCHAR(255)");
    } else {
        @$conn->query("ALTER TABLE users ADD COLUMN password_hash VARCHAR(255) DEFAULT NULL");
    }
}

// Improve error handling for AJAX requests: don't return empty responses on fatal errors.
// For POST actions (AJAX), register shutdown/exception handlers so client receives JSON error message
// Temporary debug display: enable error output when visiting with ?__debug=1
// NOTE: This is intended for short-term debugging. Remove or restrict this in production.
if(isset($_GET['__debug']) && $_GET['__debug'] === '1'){
    ini_set('display_errors', '1');
    ini_set('display_startup_errors', '1');
    error_reporting(E_ALL);
} else {
    if(!ini_get('display_errors')){
        ini_set('display_errors', '0');
    }
}
ini_set('log_errors', '1');

if(isset($_POST['action'])){
    register_shutdown_function(function(){
        $err = error_get_last();
        if($err && in_array($err['type'], [E_ERROR, E_PARSE, E_CORE_ERROR, E_COMPILE_ERROR, E_USER_ERROR])){
            if(!headers_sent()) header('Content-Type: application/json');
            $msg = isset($err['message']) ? $err['message'] : 'Fatal error';
            echo json_encode(['status'=>'error','message'=>'Server error: '.$msg]);
        }
    });

    set_exception_handler(function($ex){
        if(!headers_sent()) header('Content-Type: application/json');
        echo json_encode(['status'=>'error','message'=>'Exception: '. $ex->getMessage()]);
        exit;
    });
}

/* ================================
   AJAX HANDLER
   ================================ */
if(isset($_POST['action'])){
    $action = $_POST['action'];
    header('Content-Type: application/json');

    if($action==='signup'){
        $username = trim($_POST['username'] ?? '');
        $email = trim($_POST['email'] ?? '');
        $password = $_POST['password'] ?? '';

        // basic server-side validation
        if(!filter_var($email,FILTER_VALIDATE_EMAIL)){
            echo json_encode(['status'=>'error','message'=>'Invalid email']);
            exit;
        }
        if(strlen($username) < 3 || strlen($username) > 32){
            echo json_encode(['status'=>'error','message'=>'Username must be 3-32 characters']);
            exit;
        }
        if(!preg_match('/^[A-Za-z0-9_\-]+$/',$username)){
            echo json_encode(['status'=>'error','message'=>'Username may only contain letters, numbers, dash or underscore']);
            exit;
        }
        if(strlen($password) < 6){
            echo json_encode(['status'=>'error','message'=>'Password must be at least 6 characters']);
            exit;
        }

        $stmt = safe_prepare($conn, "SELECT id FROM users WHERE username=? OR email=?");
        if($stmt){
            $stmt->bind_param("ss",$username,$email);
            $stmt->execute();
            $stmt->store_result();
            if($stmt->num_rows>0){
                echo json_encode(['status'=>'error','message'=>'Username or email exists']);
                exit;
            }
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
            exit;
        }

        $hash=password_hash($password,PASSWORD_BCRYPT);
        $stmt = safe_prepare($conn, "INSERT INTO users(username,email,password_hash) VALUES(?,?,?)");
        if($stmt){
            $stmt->bind_param("sss",$username,$email,$hash);
            $stmt->execute();
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
            exit;
        }
        // auto-login the new user
        $new_id = $conn->insert_id;
        if($new_id){
            $_SESSION['user_id'] = $new_id;
            echo json_encode(['status'=>'success','message'=>'Signup successful']);
        }else{
            echo json_encode(['status'=>'error','message'=>'Signup failed']);
        }
        exit;
    }

    if($action==='login'){
        $username=$_POST['username'] ?? '';
        $password=$_POST['password'] ?? '';
        // allow login via username OR email
        $identifier = $username;
        $stmt = safe_prepare($conn, "SELECT id,password_hash FROM users WHERE username=? OR email=?");
        if($stmt){
            $stmt->bind_param("ss", $identifier, $identifier);
            $stmt->execute();
            $stmt->store_result();
            $stmt->bind_result($id,$hash);
            $stmt->fetch();
            if($stmt->num_rows===1 && password_verify($password,$hash)){
            $_SESSION['user_id']=$id;
            echo json_encode(['status'=>'success','message'=>'Login successful']);
        }else{
            echo json_encode(['status'=>'error','message'=>'Invalid credentials']);
        }
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
        }
        exit;
    }

    if($action==='create_post'){
        if(!isset($_SESSION['user_id'])){
            echo json_encode(['status'=>'error','message'=>'Not logged in']);
            exit;
        }
        $title = $_POST['title'] ?? '';
        $description = $_POST['description'] ?? '';
        $image_path='';
        $user_id=$_SESSION['user_id'];

        if(!empty($_FILES['image']['name'])){
            $dir="uploads/";
            if(!is_dir($dir)) mkdir($dir,0755,true);
            $filename=time()."_".basename($_FILES['image']['name']);
            $target=$dir.$filename;
            if(move_uploaded_file($_FILES['image']['tmp_name'],$target)) $image_path=$target;
        }

        $stmt = safe_prepare($conn, "INSERT INTO posts(user_id,title,description,image_path) VALUES(?,?,?,?)");
        if($stmt){
            $stmt->bind_param("isss",$user_id,$title,$description,$image_path);
            $stmt->execute();
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
            exit;
        }
        echo json_encode(['status'=>'success','message'=>'Post created']);
        exit;
    }

    if($action==='contact'){
        $name = trim($_POST['name'] ?? '');
        $email = trim($_POST['email'] ?? '');
        $message = trim($_POST['message'] ?? '');
        if($name === '' || $email === '' || $message === ''){
            echo json_encode(['status'=>'error','message'=>'All fields are required']);
            exit;
        }
        if(!filter_var($email, FILTER_VALIDATE_EMAIL)){
            echo json_encode(['status'=>'error','message'=>'Invalid email address']);
            exit;
        }

        // Try to store into a simple contacts table (create if missing)
        $conn->query("CREATE TABLE IF NOT EXISTS contacts (
            id INT AUTO_INCREMENT PRIMARY KEY,
            name VARCHAR(191),
            email VARCHAR(191),
            message TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4");

        $stmt = safe_prepare($conn, "INSERT INTO contacts (name,email,message) VALUES (?,?,?)");
        if($stmt){
            $stmt->bind_param('sss',$name,$email,$message);
            if($stmt->execute()){
            // also try to email site admin (best-effort)
            $admin = 'support@finnhustle.example';
            $subject = 'New contact message from ' . $name;
            $body = "From: $name <$email>\n\n" . $message;
            @mail($admin,$subject,$body);
            echo json_encode(['status'=>'success','message'=>'Message sent — thank you']);
        }else{
            echo json_encode(['status'=>'error','message'=>'Unable to save message']);
        }
        exit;
    }

    if($action==='update_password'){
        if(!isset($_SESSION['user_id'])){ echo json_encode(['status'=>'error','message'=>'Not logged in']); exit; }
        $uid = $_SESSION['user_id'];
        $current = $_POST['current_password'] ?? '';
        $new = $_POST['new_password'] ?? '';
        if(strlen($new) < 6){ echo json_encode(['status'=>'error','message'=>'New password too short']); exit; }

        $stmt = safe_prepare($conn, "SELECT password_hash FROM users WHERE id=?");
        if($stmt){
            $stmt->bind_param('i',$uid); $stmt->execute(); $stmt->bind_result($hash); $stmt->fetch();
            if(!password_verify($current,$hash)) { echo json_encode(['status'=>'error','message'=>'Current password incorrect']); exit; }
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']); exit;
        }

        $newhash = password_hash($new,PASSWORD_BCRYPT);
        $stmt = safe_prepare($conn, "UPDATE users SET password_hash=? WHERE id=?");
        if($stmt){
            $stmt->bind_param('si',$newhash,$uid);
            if($stmt->execute()) echo json_encode(['status'=>'success','message'=>'Password updated']);
            else echo json_encode(['status'=>'error','message'=>'Database error']);
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
        }
        exit;
    }

    if($action==='send_verification'){
        if(!isset($_SESSION['user_id'])){ echo json_encode(['status'=>'error','message'=>'Not logged in']); exit; }
        $uid = $_SESSION['user_id'];

        // Ensure columns exist (email_verified, verify_token)
        $check = $conn->query("SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA=DATABASE() AND TABLE_NAME='users' AND COLUMN_NAME IN ('email_verified','verify_token')");
        $found = [];
        if($check && $check instanceof mysqli_result){
            while($r = $check->fetch_assoc()) $found[] = $r['COLUMN_NAME'];
        } else {
            error_log('Could not read INFORMATION_SCHEMA for email verification check: ' . $conn->error);
            $found = [];
        }
        if(!in_array('email_verified',$found)){
            @$conn->query("ALTER TABLE users ADD COLUMN email_verified TINYINT(1) DEFAULT 0");
        }
        if(!in_array('verify_token',$found)){
            @$conn->query("ALTER TABLE users ADD COLUMN verify_token VARCHAR(128) DEFAULT NULL");
        }

        $token = bin2hex(random_bytes(16));
        $stmt = safe_prepare($conn, "UPDATE users SET verify_token=? , email_verified=0 WHERE id=?");
        if($stmt){
            $stmt->bind_param('si',$token,$uid);
            $stmt->execute();
            $stmt->close();
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
            exit;
        }

        // Use the fixed server IP for public links in this environment
        $site_ip = '192.168.10.40';
        $scheme = (isset($_SERVER['HTTPS']) && $_SERVER['HTTPS']!=='off') ? 'https' : 'http';
        $base_path = rtrim(dirname($_SERVER['REQUEST_URI']), '/\\');
        $verification_url = $scheme . '://' . $site_ip . $base_path . "/pages.php?page=verify_email&token=" . $token;

        // Try to send email (best-effort). If mail not configured, return the URL to the client for testing.
        $stmt2 = safe_prepare($conn, "SELECT email FROM users WHERE id=?");
        $uemail = null;
        if($stmt2){
            $stmt2->bind_param('i',$uid); $stmt2->execute(); $stmt2->bind_result($uemail); $stmt2->fetch();
            $stmt2->close();
        } else {
            error_log('Could not read user email for verification: ' . $conn->error);
        }
        $sent = false;
        if(!empty($uemail) && filter_var($uemail,FILTER_VALIDATE_EMAIL)){
            $subject = 'Verify your email';
            $message = "Please verify your email by visiting: " . $verification_url;
            // @mail may fail silently; still best-effort
            @$sent = mail($uemail,$subject,$message);
        }

        echo json_encode(['status'=>'success','message'=>'Verification sent'.($sent? ' to your email':' (email sending failed — open URL below to verify manually)'), 'verification_url'=>$verification_url]);
        exit;
    }

    if($action==='logout'){
        session_destroy();
        echo json_encode(['status'=>'success','message'=>'Logged out']);
        exit;
    }

    if($action==='update_settings'){
        if(!isset($_SESSION['user_id'])){
            echo json_encode(['status'=>'error','message'=>'Not logged in']);
            exit;
        }
        $uid = $_SESSION['user_id'];
        $new_username = trim($_POST['username'] ?? '');
        $new_email = trim($_POST['email'] ?? '');

        if($new_username === '' || $new_email === ''){
            echo json_encode(['status'=>'error','message'=>'Missing fields']);
            exit;
        }
        if(!filter_var($new_email,FILTER_VALIDATE_EMAIL)){
            echo json_encode(['status'=>'error','message'=>'Invalid email']);
            exit;
        }
        if(strlen($new_username) < 3 || strlen($new_username) > 32){
            echo json_encode(['status'=>'error','message'=>'Username must be 3-32 characters']);
            exit;
        }
        if(!preg_match('/^[A-Za-z0-9_\-]+$/',$new_username)){
            echo json_encode(['status'=>'error','message'=>'Username may only contain letters, numbers, dash or underscore']);
            exit;
        }

        // ensure username/email not used by other users
        $stmt = safe_prepare($conn, "SELECT id FROM users WHERE (username=? OR email=?) AND id<>?");
        if($stmt){
            $stmt->bind_param('ssi',$new_username,$new_email,$uid);
            $stmt->execute();
            $stmt->store_result();
            if($stmt->num_rows>0){
                $stmt->close();
                echo json_encode(['status'=>'error','message'=>'Username or email already in use']);
                exit;
            }
            $stmt->close();
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
            exit;
        }

        $stmt = safe_prepare($conn, "UPDATE users SET username=?, email=? WHERE id=?");
        if($stmt){
            $stmt->bind_param('ssi',$new_username,$new_email,$uid);
            if($stmt->execute()){
                echo json_encode(['status'=>'success','message'=>'Settings updated']);
            }else{
                echo json_encode(['status'=>'error','message'=>'Database error']);
            }
            $stmt->close();
        } else {
            echo json_encode(['status'=>'error','message'=>'Database error (prepare failed)']);
        }
        exit;
    }
}

// Email verification endpoint via GET token (link click)
if(isset($_GET['token'])){
    $token = $_GET['token'];
    if($token){
        // Ensure DB columns exist
        $check = $conn->query("SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA=DATABASE() AND TABLE_NAME='users' AND COLUMN_NAME IN ('email_verified','verify_token')");
        $found = [];
        if($check && $check instanceof mysqli_result){
            while($r = $check->fetch_assoc()) $found[] = $r['COLUMN_NAME'];
        } else {
            error_log('Could not read INFORMATION_SCHEMA for email verification GET: ' . $conn->error);
            $found = [];
        }
        if(!in_array('email_verified',$found)){
            @$conn->query("ALTER TABLE users ADD COLUMN email_verified TINYINT(1) DEFAULT 0");
        }
        if(!in_array('verify_token',$found)){
            @$conn->query("ALTER TABLE users ADD COLUMN verify_token VARCHAR(128) DEFAULT NULL");
        }

        $stmt = safe_prepare($conn, "SELECT id FROM users WHERE verify_token=? LIMIT 1");
        if($stmt){
            $stmt->bind_param('s',$token);
            $stmt->execute();
            $stmt->bind_result($uid);
            $stmt->fetch();
            $stmt->close();
            if($uid){
                $stmt2 = safe_prepare($conn, "UPDATE users SET email_verified=1, verify_token=NULL WHERE id=?");
                if($stmt2){
                    $stmt2->bind_param('i',$uid);
                    $stmt2->execute();
                } else {
                    error_log('Failed to prepare update for email verification: ' . $conn->error);
                }
                // show a simple page
                echo "<html><body><h2>Email verified</h2><p>Your email has been verified. <a href=\"pages.php?page=profile\">Go to profile</a></p></body></html>";
                exit;
            }else{
                echo "<html><body><h2>Invalid token</h2><p>The verification token is invalid or expired.</p></body></html>";
                exit;
            }
        } else {
            echo "<html><body><h2>Server error</h2><p>Unable to validate token.</p></body></html>";
            exit;
        }
    }
}

/* ================================
   CHECK LOGGED-IN STATUS
   ================================ */
$is_logged_in=false;
$user_name="Guest";
if(isset($_SESSION['user_id'])){
    $stmt = safe_prepare($conn, "SELECT username FROM users WHERE id=?");
    if($stmt){
        $stmt->bind_param("i",$_SESSION['user_id']);
        $stmt->execute();
        $stmt->bind_result($uname);
        $stmt->fetch();
        if($uname){$is_logged_in=true;$user_name=$uname;}
        $stmt->close();
    } else {
        error_log('Could not prepare user lookup: ' . $conn->error);
    }
}

/* ================================
   FETCH POSTS
   ================================ */
$posts = [];
$result = $conn->query("SELECT p.*, u.username FROM posts p JOIN users u ON p.user_id=u.id ORDER BY p.created_at DESC");
if($result && $result instanceof mysqli_result){
    while($row = $result->fetch_assoc()) { $posts[] = $row; }
} else {
    // Could not fetch posts (missing table, permissions, or other DB issue). Log and continue with empty list.
    if($conn->error){ error_log('Posts fetch failed: ' . $conn->error); }
    $posts = [];
}
